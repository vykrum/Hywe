	</ItemGroup>
	
	<ItemGroup>
		<PackageReference Include="Bolero" Version="0.24.39" />
		<PackageReference Include="Bolero.Build" Version="0.24.39" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.*" />
	</ItemGroup>
</Project>